{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "default_agent": "build",
  "subagent_depth": 1,
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff*": "allow"
    },
    "edit": "ask"
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow"
      }
    },
    "plan": {
      "permission": {
        "edit": "deny"
      }
    }
  }
}
